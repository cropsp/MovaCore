<Window
    x:Class="LayoutConverter.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    Title="Налаштування конвертера">

    <Grid>
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            IconSource="/Assets/tray_icon.ico"
            ToolTipText="Layout Converter">
            
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Налаштування" Command="{Binding ShowSettingsCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Вихід" Command="{Binding ExitApplicationCommand}" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="Конвертер розкладки активний!" FontSize="24" FontWeight="SemiBold"/>
            <TextBlock Text="Натисни Alt + Q щоб змінити розкладку виділеного тексту." />
        </StackPanel>
    </Grid>
</Window>
